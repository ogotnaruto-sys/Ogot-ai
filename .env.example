# ==========================================================
# Ogot-AI Storyboard - Environment Variables
# ==========================================================
# Copy this file to `.env` and fill in your real keys.
# Vite only exposes vars prefixed with VITE_ to the browser.
# ==========================================================

# Image generation provider (swap with your choice)
# Options handled in src/lib/aiClient.js: "stub" | "openai" | "replicate" | "stability"
VITE_IMAGE_PROVIDER=stub

# OpenAI (DALL-E 3 / gpt-image-1)
VITE_OPENAI_API_KEY=

# Replicate (Flux, SDXL, etc.)
VITE_REPLICATE_API_TOKEN=

# Stability AI
VITE_STABILITY_API_KEY=

# Anthropic Claude (used for caption + prompt enhancement, NOT images)
VITE_ANTHROPIC_API_KEY=
VITE_CLAUDE_MODEL=claude-opus-4-5
